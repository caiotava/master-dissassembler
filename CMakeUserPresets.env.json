{
  "version": 2,
  "configurePresets": [
    {
      "name": "common",
      "inherits": "vcpkg",
      "environment": {
        "VCPKG_ROOT": "$env{HOME}/.vcpkg-clion/vcpkg",
      }
    },
    {
      "name": "Debug",
      "inherits": "common",
      "binaryDir": "${sourceDir}/cmake-build-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "Release",
      "inherits": "common",
      "binaryDir": "${sourceDir}/cmake-build-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
}